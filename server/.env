# Host SMTP Gmail biasa
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# Username Gmail yang dipakai untuk mengirim
SMTP_USER=your_account@gmail.com

# SMTP password: App Password (bukan password utama)
SMTP_PASS=your_app_password

# Penerima (email perusahaan)
MAIL_TO=senasaka141210@gmail.com

# Opsional: alamat pengirim (bisa sama dengan SMTP_USER)
MAIL_FROM="Lele Sehat Prima" <your_account@gmail.com>

# Opsional: jika ingin kirim ke beberapa penerima, pisahkan dengan koma
# MAIL_TO="a@gmail.com,b@gmail.com"

PORT=3000

